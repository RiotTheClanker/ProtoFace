# ── PlatformIO ────────────────────────────────────────────────────────────────
# Build artifacts — never commit these; CI regenerates them
.pio/

# PlatformIO IDE / VSCode integration files (machine-specific)
.vscode/.browse.c_cpp.db*
.vscode/c_cpp_properties.json
.vscode/launch.json
.vscode/ipch
.vscode/extensions.json

# ── Compiled firmware ─────────────────────────────────────────────────────────
# Binaries are produced by CI and attached as release assets instead
*.elf
*.bin
*.uf2
*.map
*.lst
*.a
*.o

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── Windows ───────────────────────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── Linux ─────────────────────────────────────────────────────────────────────
*~

# ── Editor temp files ─────────────────────────────────────────────────────────
*.swp
*.swo
*.orig

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
